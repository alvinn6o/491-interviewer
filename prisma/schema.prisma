generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Account {
  id                       String  @id @default(cuid())
  userId                   String
  type                     String
  provider                 String
  providerAccountId        String
  refresh_token            String?
  access_token             String?
  expires_at               Int?
  token_type               String?
  scope                    String?
  id_token                 String?
  session_state            String?
  refresh_token_expires_in Int?
  user                     User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id                String             @id @default(cuid())
  name              String?
  email             String?            @unique
  emailVerified     DateTime?
  image             String?
  password          String?
  accounts          Account[]
  interviewSessions InterviewSession[]
  resumeAnalyses    ResumeAnalysis[]
  sessions          Session[]
  profile           UserProfile?
  settings          UserSettings?
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model UserProfile {
  id           String   @id @default(cuid())
  userId       String   @unique
  firstName    String?
  lastName     String?
  phoneNumber  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  emailAddress String?
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UserSettings {
  id              String  @id @default(cuid())
  userId          String  @unique
  prefersDarkMode Boolean @default(false)
  languagePref    String? @default("JavaScript")
  user            User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model ResumeAnalysis {
  id             String   @id @default(cuid())
  userId         String
  resumeName     String
  jobDescription String?
  atsScore       Int?
  matchScore     Float?
  feedback       Json
  analyzedAt     DateTime @default(now())
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model InterviewSession {
  id                      String                    @id @default(cuid())
  userId                  String
  type                    InterviewType
  status                  SessionStatus             @default(IN_PROGRESS)
  startedAt               DateTime                  @default(now())
  completedAt             DateTime?
  overallScore            Float?
  feedback                Json?
  pausedAt                DateTime?
  prompt                  String?
  question1Id             String?
  question2Id             String?
  resumedAt               DateTime?
  responses               InterviewResponse[]
  user                    User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  StoredBehavioralSession StoredBehavioralSession[]

  @@index([userId])
}

model InterviewResponse {
  id         String           @id @default(cuid())
  sessionId  String
  question   String
  answer     String
  score      Float?
  feedback   String?
  answeredAt DateTime         @default(now())
  session    InterviewSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
}

model TechnicalQuestion {
  id           String     @id
  difficulty   String
  category     String
  createdAt    DateTime   @default(now())
  description  String
  functionName String
  outputType   String
  params       Json
  slug         String     @unique
  starterCode  Json
  title        String
  testCases    TestCase[]
}

model TestCase {
  id             String            @id @default(cuid())
  input          Json
  expectedOutput String
  isHidden       Boolean           @default(false)
  problemId      String
  problem        TechnicalQuestion @relation(fields: [problemId], references: [id], onDelete: Cascade)
}

model InterviewReport {
  id         String   @id @default(cuid())
  userId     String
  sessionId  String
  summary    String
  isFavorite Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([sessionId])
}

model BehavioralPrompt {
  id     String @id
  prompt String
}

model StoredBehavioralSession {
  id               String           @id
  sessionId        String
  transcript       String?
  videoURL         String?
  feedback         Json?
  InterviewSession InterviewSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

enum InterviewType {
  BEHAVIORAL
  TECHNICAL
}

enum SessionStatus {
  IN_PROGRESS
  COMPLETED
  ABANDONED
}
